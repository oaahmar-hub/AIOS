# AIOS runtime config example.
# Copy to config.env and fill values locally. Never commit real secrets.

# Airtable CRM writeback
# Prefer AIRTABLE_PAT for Railway/runtime. AIRTABLE_TOKEN remains supported for local gateway compatibility.
AIRTABLE_BASE_ID=<airtable_base_id>
AIRTABLE_CONTACTS_TABLE=<airtable_contacts_table_id>
AIRTABLE_LEADS_TABLE=<airtable_leads_table_id>
AIRTABLE_COMMS_TABLE=<airtable_comms_table_id>
AIRTABLE_PAT=<airtable_personal_access_token>
AIRTABLE_TOKEN=<airtable_personal_access_token>
AIOS_AIRTABLE_REPLAY_INTERVAL_SECONDS=<seconds>
AIOS_AIRTABLE_REPLAY_BATCH_SIZE=<count>

# Wasender outbound
WASENDER_API_KEY=<wasender_api_key>

# Gateway
WA_SIMPLE_GATEWAY_PORT=<local_port>
WA_SIMPLE_OPENAI_ENDPOINT=<reply_webhook_url>
AIOS_ENV=<production_or_local>
AIOS_AUTH_MODE=<basic_or_off>
AIOS_WEBHOOK_SECRET=<webhook_shared_secret>
AIOS_ADMIN_SECRET=<admin_shared_secret>
AIOS_BASIC_AUTH_USER=<admin_basic_auth_user>
AIOS_BASIC_AUTH_PASSWORD=<admin_basic_auth_password>
AIOS_OWNER_PHONE=<owner_phone_digits>
AIOS_WHATSAPP_AUTOPILOT_MODE=<mode>
AIOS_WHATSAPP_REPLY_MODE=<hold_or_auto>
AIOS_WHATSAPP_VERIFY_TOKEN=<whatsapp_verify_token>

# Runtime paths
AIOS_PROJECT_DIR=<absolute_or_container_project_dir>
AIOS_DATA_DIR=<data_dir>
AIOS_KNOWLEDGE_BASE_DIR=<knowledge_base_dir>
