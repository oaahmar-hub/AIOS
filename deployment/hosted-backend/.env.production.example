# AIOS hosted backend production environment.
# Placeholder values only. Do not commit real secret values.

# Required secret for outbound WhatsApp through Wasender.
WASENDER_API_KEY=<wasender_api_key>

# Recommended non-secret n8n/OpenAI reply webhook.
WA_SIMPLE_OPENAI_ENDPOINT=<reply_webhook_url>

# Recommended non-secret frontend origin, for CORS.
AIOS_ALLOWED_ORIGIN=<frontend_origin>

# Required secret if private beta API routes are protected.
AIOS_BASIC_AUTH_USER=<private_beta_user>
AIOS_BASIC_AUTH_PASSWORD=<private_beta_password>

# Optional secret for provider webhook hardening.
# Only enable if the Wasender webhook can send this header or payload field.
AIOS_WEBHOOK_SECRET=<provider_webhook_secret>

# Optional runtime path override. Docker default is /app/AIOS.
AIOS_ROOT=<aios_root_path>

# Optional CRM connector values. Required only for hosted CRM write-back.
AIRTABLE_API_KEY=<airtable_api_key>
AIRTABLE_BASE_ID=<airtable_base_id>
AIRTABLE_TABLE_ID=<airtable_table_id>
AIRTABLE_LEADS_TABLE=<airtable_leads_table_id>
AIRTABLE_CONTACTS_TABLE=<airtable_contacts_table_id>
